rules_version = '2';

// Canonical Firestore rules for Loot Box Creator — ANONYMOUS AUTH edition.
// Deploy via Firebase console (Firestore > Rules) or `firebase deploy --only firestore:rules`.
//
// DEPLOY ORDER (matters!):
//   1. Firebase console: Authentication > Sign-in method > Anonymous > Enable
//   2. Ship the client that signs in anonymously (src/services/firebase.js
//      ensureSignedIn) and attaches creatorUid to new shared boxes
//   3. Fill in the isAdmin() allowlist below with the uids shown in the
//      headers of box-admin.html and shared-box-cleanup.html
//   4. THEN paste these rules. Clients still running the pre-auth bundle
//      will fail writes until they refresh (GitHub Pages caches the page
//      for ~10 minutes, so the window is short).
//
// Model: everyone is an anonymous Firebase user (uid is stable per browser
// profile). Shared boxes carry creatorUid; only that uid (or an admin) can
// edit or delete the box. Boxes created before auth ("legacy": have
// creatorDeviceId but no creatorUid) are claimable — the first signed-in
// client whose device created them stamps its uid via backfillCreatorUid.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Admin browser profiles. Each admin page shows its uid in the header
    // after signing in — paste those uids here. NOTE: clearing a browser's
    // site data issues a new uid; update this list if that happens.
    function isAdmin() {
      return signedIn() && request.auth.uid in [
        // Frank's browser on frankdimicco.github.io (shared-box-cleanup.html)
        'DOGDrkNIyTcL7HxZwtthNHM4v7k1',
        // Frank's local box-admin.html (file:// is its own origin/uid)
        'BvEehYJGw3ZIgm90BK5QDgeT5X72'
      ];
    }

    match /sharedBoxes/{boxId} {
      allow read: if true;

      // Doc IDs are 6-char share codes (see generateShareCode). The creator
      // must stamp their own uid on the box at creation.
      allow create: if signedIn()
                    && boxId.matches('[A-Z0-9]{6}')
                    && request.resource.data.creatorUid == request.auth.uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 100
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && request.resource.data.items.size() <= 50
                    && request.resource.data.creatorDeviceId is string
                    && request.resource.data.creatorDeviceId.size() > 0;

      // Two legitimate update shapes:
      //  1. Any signed-in participant appending ONE pull. pullHistory may
      //     only grow by exactly one entry and is hard-capped.
      //  2. The creator (or an admin) editing settings. This path never
      //     touches pullHistory (client strips it), must preserve
      //     creatorDeviceId, and must not reassign ownership. Legacy docs
      //     (no creatorUid yet) may have it set — but only to the caller's
      //     own uid (the one-time claim used by backfillCreatorUid).
      allow update: if signedIn() && (
                      (
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['pullHistory', 'updatedAt', 'lastActivity'])
                        && request.resource.data.pullHistory is list
                        && resource.data.pullHistory is list
                        && request.resource.data.pullHistory.size()
                             == resource.data.pullHistory.size() + 1
                        && request.resource.data.pullHistory.size() <= 2000
                      ) || (
                        !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['pullHistory'])
                        && (
                          !('creatorDeviceId' in resource.data)
                          || request.resource.data.creatorDeviceId
                               == resource.data.creatorDeviceId
                        )
                        && (
                          (
                            ('creatorUid' in resource.data)
                            && resource.data.creatorUid == request.auth.uid
                            && request.resource.data.creatorUid
                                 == resource.data.creatorUid
                          ) || (
                            !('creatorUid' in resource.data)
                            && (
                              !('creatorUid' in request.resource.data)
                              || request.resource.data.creatorUid == request.auth.uid
                            )
                          ) || isAdmin()
                        )
                      )
                    );

      // Creator-only delete at last (legacy boxes stay deletable by anyone
      // signed in until they're claimed — acceptable one-time window).
      allow delete: if signedIn() && (
                      isAdmin()
                      || !('creatorUid' in resource.data)
                      || resource.data.creatorUid == request.auth.uid
                    );

      // Item photos live here (out of the main doc so pulls don't
      // re-broadcast them). Bounded by the 1MB doc limit.
      // Writes are creator-or-admin only — previously ANY signed-in user
      // could overwrite (or bloat) any box's images. During initial
      // creation the parent box doc doesn't exist yet (saveSharedBox writes
      // meta first, then the box), so permit that one window. Legacy boxes
      // (no creatorUid) stay writable until claimed, matching the parent.
      match /meta/{doc} {
        allow read: if true;
        allow write: if signedIn() && (
                       isAdmin()
                       || !exists(/databases/$(database)/documents/sharedBoxes/$(boxId))
                       || !('creatorUid' in get(/databases/$(database)/documents/sharedBoxes/$(boxId)).data)
                       || get(/databases/$(database)/documents/sharedBoxes/$(boxId)).data.creatorUid == request.auth.uid
                     );
      }
    }

    match /boxCatalog/{boxId} {
      allow read: if true;
      // Locked at last (was world-writable pre-auth): only admin browser
      // profiles manage the catalog via box-admin.html.
      allow write: if isAdmin();
    }

    match /boxTemplates/{templateId} {
      allow read: if true;

      function validTemplate() {
        return request.resource.data.name is string
               && request.resource.data.name.size() > 0
               && request.resource.data.name.size() <= 100
               && request.resource.data.items is list
               && request.resource.data.items.size() > 0
               && request.resource.data.items.size() <= 50;
      }

      // `curated` templates surface in every client's shelf
      // (fetchCuratedTemplates). Only an admin may publish one; everyone
      // else must leave the flag false/absent. The client never sets it.
      function curatedOk() {
        return isAdmin()
               || !('curated' in request.resource.data)
               || request.resource.data.curated == false;
      }

      // Create: any signed-in user, but they may only stamp their OWN uid
      // as creator (or none). Templates carry creatorUid from saveBoxTemplate.
      allow create: if signedIn() && validTemplate() && curatedOk()
                    && (
                      !('creatorUid' in request.resource.data)
                      || request.resource.data.creatorUid == request.auth.uid
                    );

      // Update (re-sharing a local box overwrites its template doc): only
      // the original creator or an admin, and ownership can't be reassigned.
      // Previously ANY signed-in user could overwrite ANY template by id.
      // Legacy templates (no creatorUid) stay updatable until claimed.
      allow update: if signedIn() && validTemplate() && curatedOk()
                    && (
                      isAdmin()
                      || (
                        !('creatorUid' in resource.data)
                        && (
                          !('creatorUid' in request.resource.data)
                          || request.resource.data.creatorUid == request.auth.uid
                        )
                      )
                      || (
                        resource.data.creatorUid == request.auth.uid
                        && request.resource.data.creatorUid == resource.data.creatorUid
                      )
                    );

      allow delete: if false;
    }
  }
}
